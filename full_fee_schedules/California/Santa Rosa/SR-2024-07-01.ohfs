# Santa Rosa, CA — Housing Permit Fee Schedule
# Effective: July 1, 2024
#
# Source: City of Santa Rosa Planning and Economic Development fee schedule.
# Note: Fee values in this file have NOT been verified against the official
# source — it is not clear whether the amounts below reflect the current
# fee schedule. Confirm against the source URL in metadata before any use.
---
metadata:
  effective_date: 2024-07-01
  city_name: "Santa Rosa"
  state: CA
  fee_currency: USD
  jurisdiction_type: city
  source_url: "https://srcity.org/214/Planning-Economic-Development"
  notes: "UNVERIFIED — fee amounts have not been confirmed against the official fee schedule; it is not clear whether the values below match current rates. Reflects post-2017 fire rebuilding fee waivers expired."

fee_structure:

  SINGLE_FAMILY:
    tier_starts:
      - 0
