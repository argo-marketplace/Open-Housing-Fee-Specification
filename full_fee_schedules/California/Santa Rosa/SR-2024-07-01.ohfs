      - 100000
      - 500000
      - 1000000
    tier_prices:
      - 0.02080
      - 0.01680
      - 0.01250
      - 0.00940
      - 0.00710
    building_permit_fee: Tiered
    plan_check_rate: 0.65
    plan_check_fee: "plan_check_rate*building_permit_fee"
    park_impact_fee: 5400
    transportation_impact_fee: 3650
    water_connection_fee: 4800
    sewer_connection_fee: 5950
    school_fee: "4.79*gross_sq_ft"
    strong_motion_fee: "0.00013*project_valuation"
    total_fee: "building_permit_fee+plan_check_fee+park_impact_fee+transportation_impact_fee+water_connection_fee+sewer_connection_fee+school_fee+strong_motion_fee"

  ADU:
    building_permit_fee: 1250
